<!DOCTYPE html>
<head>
    <link rel="stylesheet" href="/css/navbar.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

</head>
<body>
    <form action="/addPost" method="POST" enctype="multipart/form-data" class="mb-4">
        <div class="mb-3">
            <label for="title" class="form-label">Title:</label>
            <input type="text" id="title" name="title" class="form-control" placeholder="Enter title" required> <br>
        </div>

        <div class="mb-3">
            <label for="categories" class="form-label">Category:</label> <br>
            <select id="categories" name="categories" class="form-select" required>
                <option value="">-- Select a category --</option>
                <option value="Military">Military</option>
                <option value="Culture">Culture</option>
                <option value="Politics">Politics</option>
                <option value="Archaeology">Archaeology</option>
                <option value="Other">Other</option>
            </select>
        </div>
        
        <div class="mb-3">
            <label for="image" class="form-label">Upload Image:</label>
            <input type="file" id="image" name="image" class="form-control" accept="image/*" required> <br>
        </div>
        
        <div class="mb-3"> 
            <label for="caption" class="form-label">Caption:</label>
            <textarea id="caption" name="caption" class="form-control" placeholder="Enter caption"></textarea> <br>
        </div>
        
        <button type="submit" class="btn btn-success">Add Post</button>
    </form>

</body>