<!DOCTYPE html>

<head>
    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <title>Register | Histogram</title>

    <link rel="stylesheet" href="/css/register.css">
</head>


<body>

    <main class="register-page">

        <section class="register-card">

            <div class="register-brand">

                <div class="brand-logo">
                    H
                </div>

                <div class="brand-details">
                    <h2 class="brand-name">Histogram</h2>
                    <p class="brand-tagline">Stories from the past</p>
                </div>

            </div>


            <div class="register-heading">

                <span class="heading-label">
                    Join Histogram
                </span>

                <h1>
                    Create Account
                </h1>

                <p>
                    Create an account to share and manage historical posts.
                </p>

            </div>


            <% if (typeof error !== 'undefined' && error) { %>

                <div class="error-message">

                    <%= error %>

                </div>

            <% } %>

            <form
                action="/register"
                method="POST"
                class="register-form"
            >


                <div class="form-group">

                    <label for="name">
                        Full name
                    </label>


                    <div class="input-container">

                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8zm0 2c-4.4 0-8 2.2-8 5v1h16v-1c0-2.8-3.6-5-8-5z"/>
                        </svg>


                        <input
                            type="text"
                            id="name"
                            name="name"
                            placeholder="Enter your full name"
                            autocomplete="name"
                            required
                        >

                    </div>

                </div>




                <div class="form-group">

                    <label for="email">
                        Email address
                    </label>


                    <div class="input-container">

                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"/>
                        </svg>


                        <input
                            type="email"
                            id="email"
                            name="email"
                            placeholder="Enter your email"
                            autocomplete="email"
                            required
                        >

                    </div>

                </div>




                <div class="form-group">

                    <label for="password">
                        Password
                    </label>


                    <div class="input-container">

                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M18 8h-1V6a5 5 0 0 0-10 0v2H6a2 2 0 0 0-2 2v10h16V10a2 2 0 0 0-2-2zm-9-2a3 3 0 0 1 6 0v2H9V6zm4 9.73V18h-2v-2.27a2 2 0 1 1 2 0z"/>
                        </svg>


                        <input
                            type="password"
                            id="password"
                            name="password"
                            placeholder="Create a password"
                            autocomplete="new-password"
                            required
                        >

                    </div>

                </div>




                <div class="form-group">

                    <label for="role">
                        Account role
                    </label>


                    <div class="select-container">


                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M12 2 3 6v6c0 5.25 3.84 10.16 9 11.5 5.16-1.34 9-6.25 9-11.5V6l-9-4zm0 2.18L19 7.3V12c0 4.17-2.84 8.18-7 9.45C7.84 20.18 5 16.17 5 12V7.3l7-3.12z"/>
                        </svg>


                        <select
                            id="role"
                            name="role"
                            required
                        >

                            <option value="" selected disabled>
                                Select an account role
                            </option>


                            <option value="user">
                                User
                            </option>


                            <option value="admin">
                                Admin
                            </option>


                        </select>


                        <svg
                            class="select-arrow"
                            viewBox="0 0 24 24"
                            aria-hidden="true"
                        >

                            <path d="m7 10 5 5 5-5z"/>

                        </svg>


                    </div>

                </div>



                <button
                    type="submit"
                    class="register-button"
                >

                    <span>
                        Create Account
                    </span>


                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M15 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm-9-2V7H4v3H1v2h3v3h2v-3h3v-2H6zm9 4c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                    </svg>


                </button>


            </form>





            <div class="login-section">

                <span>
                    Already have an account?
                </span>


                <a href="/">
                    Login
                </a>


            </div>


        </section>





        <p class="register-footer">
            Explore history. Share knowledge. Preserve stories.
        </p>


    </main>


</body>

</html>