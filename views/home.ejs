<!DOCTYPE html>
<html>
<head>
  <title>Histogram</title>
  <link rel="stylesheet" href="/css/navbar.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

</head>
<body class="container mt-4">
  <%- include('partials/navbar.ejs')%>\

  <% if (errorMessage && errorMessage.length > 0) { %>
    <div class="alert alert-danger">
        <%= errorMessage[0] %>
    </div>
  <% } %>

  <h2>Histogram Entries</h2>
  <div class="row">
    <% for(let hp = 0 ; hp < histogram_table.length ; ++ hp   ) { %>
      <div class="col-md-4 mb-4">

        <div class="card">

          <div class="card-body">
            <h5 class="card-title"><%= histogram_table[hp].title %></h5>
            <p class="card-text"><strong>Category:</strong> <%= histogram_table[hp].categories %></p>
            <img src="/images/<%= histogram_table[hp].image %>" class="card-img-top" alt="<%= histogram_table[hp].title %>">
            <p class="card-text"><%= histogram_table[hp].caption %></p>
            
            <form action="/deletePost/<%= histogram_table[hp].postId %>" method="post">
              <button class="btn btn-primary" style="color: black; background-color: red;">Delete</button>

            </form>
          </div>

        </div>

      </div>
    <% } %>
  </div>
</body>
</html>