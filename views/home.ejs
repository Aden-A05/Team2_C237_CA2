<!DOCTYPE html>
<html>

<head>
  <title>
    <% if (user && user.role==='admin' ) { %>
      <%= activePage==='adminDashboard' ? 'Admin Dashboard' : 'Admin Home' %>
        <% } else { %>
          Histogram
          <% } %>
  </title>
  <link rel="stylesheet" href="/css/navbar.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body class="container mt-4">
  <%- include('partials/navbar') %>

    <% if (errorMessage && errorMessage.length> 0) { %>
      <div class="alert alert-danger">
        <%= errorMessage[0] %>
      </div>
      <% } %>

        <% if (approvedMessage && approvedMessage.length> 0) { %>
          <div class="alert alert-success">
            <%= approvedMessage[0] %>
          </div>
          <% } %>

            <!-- Admin Dashboard -->
            <% if (user && user.role==='admin' && activePage==='adminDashboard' ) { %>
              <h2 class="mb-4">Admin Analytics Dashboard</h2>

              <div class="card p-4 shadow-sm mb-4">
                <div class="row">
                  <div class="col-md-6">
                    <h4>Total Posts: <%= totalPosts %>
                    </h4>
                    <h4>Total Users: <%= totalUsers %>
                    </h4>
                  </div>
                  <div class="col-md-6">
                    <canvas id="categoryChart"></canvas>
                  </div>
                </div>
              </div>




                <!-- Aden Enhancement-->
                <h2>Approval List :</h2>

                <div class="row">
                  <% for(let hp=0; hp < histogram_table.length; hp ++) { %>
                    <%if(histogram_table[hp].is_approved===0){%>
                      <div class="col-md-4 mb-4">
                        <div class="card">
                          <div class="card-body">
                            <h5 class="card-title">
                              <%= histogram_table[hp].title %>
                            </h5>
                            <p class="card-text"><strong>Category:</strong>
                              <%= histogram_table[hp].categories %>
                            </p>
                            <img src="/images/<%= histogram_table[hp].image %>" class="card-img-top"
                              alt="<%= histogram_table[hp].title %>">
                            <p class="card-text">
                              <%= histogram_table[hp].caption %>
                            </p>
                            <p class="card-text"><em>Posted by: <%= histogram_table[hp].posted_by %> (<%=
                                    histogram_table[hp].posted_role %>)</em></p>

                            <!-- Aden Delete part -->
                            <form action="/deletePost/<%= histogram_table[hp].postId %>" method="post">
                              <button class="btn btn-danger">Delete</button>
                            </form>
                            <br>
                            <!--Aden Enchancement Approval button-->
                            <form action="/approvePost/<%= histogram_table[hp].postId %>" method="post">
                              <button class="btn btn-primary">Approve</button>
                            </form>





                            <%}%>
                          </div>
                        </div>
                      </div>
                      <%}%>


                        <!-- User Role List with Post Counts -->
                        <h3 class="mt-5">User List</h3>
                        <div class="row">
                          <div class="col-md-6">
                            <h4>Admins</h4>
                            <hr>
                            <ul class="list-group mb-4">
                              <% userList.filter(u=> u.role === 'admin').forEach(admin => { %>
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                  <%= admin.name %>
                                    <span class="badge bg-primary rounded-pill">
                                      <%= admin.post_count %> posts
                                    </span>
                                </li>
                                <% }) %>
                            </ul>
                          </div>

                          <div class="col-md-6">
                            <h4>Normal Users</h4>
                            <hr>
                            <ul class="list-group">
                              <% userList.filter(u=> u.role !== 'admin').forEach(normal => { %>
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                  <%= normal.name %>
                                    <span class="badge bg-secondary rounded-pill">
                                      <%= normal.post_count %> posts
                                    </span>
                                </li>
                                <% }) %>
                            </ul>
                          </div>
                        </div>
                        <% } %>


                          <!-- Admin Home -->
                          <% if (user && user.role==='admin' && activePage==='adminHome' ) { %>
                            <h2>All User Posts (Admin View)</h2>

                            <!--Danish's Search bar-->
                            <form id="search-form" method="GET" action="/searched">

                              <label style="font-weight:bold; font-size:16px; color:#333;">Search By:</label>

                              <div class="search-type-selectors" style="margin:8px 0;">
                                <label style="display:block; margin-bottom:6px; color:#444;">
                                  <input type="radio" name="searchType" value="title" checked onclick="titleSearch()"
                                    style="margin-right:6px;"> Search by Title
                                </label>
                                <label style="display:block; margin-bottom:6px; color:#444;">
                                  <input type="radio" name="searchType" value="category" onclick="categorySearch()"
                                    style="margin-right:6px;"> Search by Category
                                </label>
                                <label style="display:block; margin-bottom:6px; color:#444;">
                                  <input type="radio" name="searchType" value="user" onclick="userSearch()"
                                    style="margin-right:6px;">
                                  Search by User
                                </label>
                              </div>


                              <div class="search-fields" style="margin-top:10px;">
                                <div id="title-field" class="field-container">
                                  <input type="text" name="titleQuery" placeholder="Enter post title..." id="q1"
                                    required
                                    style="width:25%; padding:8px; border:1px solid #bbb; border-radius:5px; font-size:14px;">
                                </div>

                                <div id="category-field" class="field-container" hidden>
                                  <select name="categoryQuery" id="q2" disabled required
                                    style="width:25%; padding:8px; border:1px solid #bbb; border-radius:5px; font-size:14px; margin-top:8px;">
                                    <option value="">-- Select a category --</option>
                                    <option value="Military">Military</option>
                                    <option value="Culture">Culture</option>
                                    <option value="Politics">Politics</option>
                                    <option value="Archaeology">Archaeology</option>
                                    <option value="Other">Other</option>
                                  </select>
                                </div>

                                <div id="user-field" class="field-container" hidden>
                                  <input type="text" name="userQuery" placeholder="Enter name of user..." id="q3"
                                    disabled required
                                    style="width:25%; padding:8px; border:1px solid #bbb; border-radius:5px; font-size:14px; margin-top:8px;">
                                </div>
                              </div>

                              <button type="submit"
                                style="margin-top:15px; padding:8px 16px; background:#4CAF50; color:white; border:none; border-radius:5px; font-size:14px; cursor:pointer;">
                                Search
                              </button><br>
                            </form>



                            <div class="row">
                              <% for(let hp=0; hp < histogram_table.length; hp ++) { %>
                                <%if(histogram_table[hp].is_approved===1){%>
                                  <div class="col-md-4 mb-4">
                                    <div class="card shadow-sm">
                                      <img src="/images/<%= histogram_table[hp].image %>" class="card-img-top"
                                        alt="<%= histogram_table[hp].title %>">
                                      <div class="card-body">
                                        <h5 class="card-title">
                                          <%= histogram_table[hp].title %>
                                        </h5>
                                        <p class="card-text"><strong>Category:</strong>
                                          <%= histogram_table[hp].categories %>
                                        </p>
                                        <p class="card-text">
                                          <%= histogram_table[hp].caption %>
                                        </p>
                                        <p class="card-text"><em>Posted by: <%= histogram_table[hp].posted_by %> (<%=
                                                histogram_table[hp].posted_role %>)</em></p>
                                        <form action="/deletePost/<%= histogram_table[hp].postId %>" method="post">
                                          <button class="btn btn-danger">Delete</button>
                                        </form>
                                      </div>
                                    </div>
                                  </div>
                                  <% } %>
                                    <% } %>
                            </div>
                            <% } %>

                              <!-- Normal User Home -->
                              <% if (!user || user.role !=='admin' ) { %>
                                <h2>Histogram Entries</h2>


                                <!--Danish's Search bar-->
                                <form id="search-form" method="GET" action="/searched">

                                  <label style="font-weight:bold; font-size:16px; color:#333;">Search By:</label>

                                  <div class="search-type-selectors" style="margin:8px 0;">
                                    <label style="display:block; margin-bottom:6px; color:#444;">
                                      <input type="radio" name="searchType" value="title" checked
                                        onclick="titleSearch()" style="margin-right:6px;"> Search by Title
                                    </label>
                                    <label style="display:block; margin-bottom:6px; color:#444;">
                                      <input type="radio" name="searchType" value="category" onclick="categorySearch()"
                                        style="margin-right:6px;"> Search by Category
                                    </label>
                                    <label style="display:block; margin-bottom:6px; color:#444;">
                                      <input type="radio" name="searchType" value="user" onclick="userSearch()"
                                        style="margin-right:6px;">
                                      Search by User
                                    </label>
                                  </div>

                                  <div class="search-fields" style="margin-top:10px;">
                                    <div id="title-field" class="field-container">
                                      <input type="text" name="titleQuery" placeholder="Enter post title..." id="q1"
                                        required
                                        style="width:25%; padding:8px; border:1px solid #bbb; border-radius:5px; font-size:14px;">
                                    </div>

                                    <div id="category-field" class="field-container" hidden>
                                      <select name="categoryQuery" id="q2" disabled required
                                        style="width:25%; padding:8px; border:1px solid #bbb; border-radius:5px; font-size:14px; margin-top:8px;">
                                        <option value="">-- Select a category --</option>
                                        <option value="Military">Military</option>
                                        <option value="Culture">Culture</option>
                                        <option value="Politics">Politics</option>
                                        <option value="Archaeology">Archaeology</option>
                                        <option value="Other">Other</option>
                                      </select>
                                    </div>

                                    <div id="user-field" class="field-container" hidden>
                                      <input type="text" name="userQuery" placeholder="Enter name of user..." id="q3"
                                        disabled required
                                        style="width:25%; padding:8px; border:1px solid #bbb; border-radius:5px; font-size:14px; margin-top:8px;">
                                    </div>
                                  </div>

                                  <button type="submit"
                                    style="margin-top:15px; padding:8px 16px; background:#4CAF50; color:white; border:none; border-radius:5px; font-size:14px; cursor:pointer;">
                                    Search
                                  </button><br>
                                </form>


                                <div class="row">
                                  <% for(let hp=0; hp < histogram_table.length; hp ++) { %>
                                    <%if(histogram_table[hp].is_approved===1){%>
                                      <div class="col-md-4 mb-4">
                                        <div class="card">
                                          <div class="card-body">
                                            <h5 class="card-title">
                                              <%= histogram_table[hp].title %>
                                            </h5>
                                            <p class="card-text"><strong>Category:</strong>
                                              <%= histogram_table[hp].categories %>
                                            </p>
                                            <img src="/images/<%= histogram_table[hp].image %>" class="card-img-top"
                                              alt="<%= histogram_table[hp].title %>">
                                            <p class="card-text">
                                              <%= histogram_table[hp].caption %>
                                            </p>
                                            <p class="card-text"><em>Posted by: <%= histogram_table[hp].posted_by %> (
                                                  <%= histogram_table[hp].posted_role %>)</em></p>
                                            <!-- Aden Delete part -->
                                            <%if(user.user_id===histogram_table[hp].user_id){%>
                                              <form action="/deletePost/<%= histogram_table[hp].postId %>"
                                                method="post">
                                                <button class="btn btn-danger">Delete</button>
                                              </form>
                                              <%}%>
                                          </div>
                                        </div>
                                      </div>
                                      <% } %>
                                        <% } %>
                                </div>
                                <% } %>
</body>

<script>
  // Danish's search bar
  const titleField = document.getElementById('title-field');
  const categoryField = document.getElementById('category-field');
  const userField = document.getElementById('user-field');

  const titleInput = document.getElementById('q1');
  const categorySelect = document.getElementById('q2');
  const userInput = document.getElementById('q3');

  function titleSearch() {
    // Show title field, hide category and user field
    titleField.removeAttribute('hidden');
    categoryField.setAttribute('hidden', true);
    userField.setAttribute('hidden', true);

    // Enable title input, disable category and user
    titleInput.removeAttribute('disabled');
    categorySelect.setAttribute('disabled', true);
    userInput.setAttribute('disabled', true);
  }

  function categorySearch() {
    // Show category field, hide title and user field
    categoryField.removeAttribute('hidden');
    titleField.setAttribute('hidden', true);
    userField.setAttribute('hidden', true);

    // Enable category dropdown, disable title and user
    categorySelect.removeAttribute('disabled');
    titleInput.setAttribute('disabled', true);
    userInput.setAttribute('disabled', true);
  }

  function userSearch() {
    // Show user field, hide title and category field
    userField.removeAttribute('hidden');
    titleField.setAttribute('hidden', true);
    categoryField.setAttribute('hidden', true);

    // Enable user field, disable title and category
    userInput.removeAttribute('disabled');
    titleInput.setAttribute('disabled', true);
    categorySelect.setAttribute('disabled', true);
  }
</script>

</html>