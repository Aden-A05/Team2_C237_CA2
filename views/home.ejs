<!DOCTYPE html>
<html>
<head>
  <title>
    <% if (user && user.role === 'admin') { %>
      <%= activePage === 'adminDashboard' ? 'Admin Dashboard' : 'Admin Home' %>
    <% } else { %>
      Histogram
    <% } %>
  </title>
  <link rel="stylesheet" href="/css/navbar.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body class="container mt-4">
  <%- include('partials/navbar') %>

  <% if (errorMessage && errorMessage.length > 0) { %>
    <div class="alert alert-danger">
      <%= errorMessage[0] %>
    </div>
  <% } %>

  <!-- Admin Dashboard -->
  <% if (user && user.role === 'admin' && activePage === 'adminDashboard') { %>
    <h2 class="mb-4">Admin Analytics Dashboard</h2>
    <div class="row mb-4">
      <div class="col-md-6">
        <div class="card p-3 shadow-sm">
          <h4>Total Posts: <%= totalPosts %></h4>
          <h4>Total Users: <%= totalUsers %></h4>
        </div>
      </div>
      <div class="col-md-6">
        <canvas id="categoryChart"></canvas>
      </div>
    </div>

    <script>
      const ctx = document.getElementById('categoryChart').getContext('2d');
      const categoryChart = new Chart(ctx, {
        type: 'bar',
        data: {
          labels: <%- JSON.stringify(categoriesData.map(c => c.categories)) %>,
          datasets: [{
            label: 'Posts per Category',
            data: <%- JSON.stringify(categoriesData.map(c => c.count)) %>,
            backgroundColor: 'rgba(54, 162, 235, 0.6)'
          }]
        },
        options: { scales: { y: { beginAtZero: true } } }
      });
    </script>
  <% } %>

  <!-- Admin Home -->
  <% if (user && user.role === 'admin' && activePage === 'adminHome') { %>
    <h2>All User Posts (Admin View)</h2>
    <div class="row">
      <% for(let hp = 0; hp < histogram_table.length; hp ++) { %>
        <div class="col-md-4 mb-4">
          <div class="card shadow-sm">
            <img src="/images/<%= histogram_table[hp].image %>" class="card-img-top" alt="<%= histogram_table[hp].title %>">
            <div class="card-body">
              <h5 class="card-title"><%= histogram_table[hp].title %></h5>
              <p class="card-text"><strong>Category:</strong> <%= histogram_table[hp].categories %></p>
              <p class="card-text"><%= histogram_table[hp].caption %></p>
              <p class="card-text"><em>Posted by: <%= histogram_table[hp].posted_by %> (<%= histogram_table[hp].posted_role %>)</em></p>
              <form action="/deletePost/<%= histogram_table[hp].postId %>" method="post">
                <button class="btn btn-danger">Delete</button>
              </form>
            </div>
          </div>
        </div>
      <% } %>
    </div>
  <% } %>

  <!-- Normal User Home -->
  <% if (!user || user.role !== 'admin') { %>
    <h2>Histogram Entries</h2>
    <div class="row">
      <% for(let hp = 0; hp < histogram_table.length; hp ++) { %>
        <div class="col-md-4 mb-4">
          <div class="card">
            <div class="card-body">
              <h5 class="card-title"><%= histogram_table[hp].title %></h5>
              <p class="card-text"><strong>Category:</strong> <%= histogram_table[hp].categories %></p>
              <img src="/images/<%= histogram_table[hp].image %>" class="card-img-top" alt="<%= histogram_table[hp].title %>">
              <p class="card-text"><%= histogram_table[hp].caption %></p>
              <p class="card-text"><em>Posted by: <%= histogram_table[hp].posted_by %> (<%= histogram_table[hp].posted_role %>)</em></p>
              <!-- Aden Delete part -->
              <%if(user.user_id === histogram_table[hp].user_id){%>
              <form action="/deletePost/<%= histogram_table[hp].postId %>" method="post">
                <button class="btn btn-danger">Delete</button>
              </form>
              <%}%>
            </div>
          </div>
        </div>
      <% } %>
    </div>
  <% } %>
</body>
</html>
